{
  "name": "sequence-of-returns-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Monte Carlo sequence-of-returns retirement simulator. Builds to a single self-contained HTML file.",
  "scripts": {
    "dev": "vite",
    "build": "npm run lint && vite build",
    "preview": "vite preview",
    "lint": "npm run lint:html && npm run lint:js",
    "lint:html": "htmlhint \"index.html\" \"src/partials/**/*.html\"",
    "lint:js": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "htmlhint": "^1.9.2",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "vite-plugin-handlebars": "^2.0.3",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "chart.js": "^4.4.7",
    "echarts": "^5.5.1",
    "echarts-gl": "^2.0.9"
  }
}
